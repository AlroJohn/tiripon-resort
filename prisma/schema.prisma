// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())

  @@map("users")
}

model Subscribers {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("subscribers")
}

model ContactUs {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_us")
}

model Booking {
  id              Int        @id @default(autoincrement())
  name            String
  email           String?
  phone           String?
  cottage         Cottages[]
  receipt         Receipt?
  number_of_adult String
  number_of_kids  String
  total_price     Float
  summary         String?
  checkIn         DateTime?
  checkOut        DateTime?
  createdAt       DateTime   @default(now())

  @@map("bookings")
}

model Receipt {
  id                Int      @id @default(autoincrement())
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId         Int      @unique
  downPaymentAmount Float
  status            String   @default("pending")
  proofFilePath     String?
  proofFileName     String?
  proofMimeType     String?
  proofViewUrl      String?
  proofUploadedAt   DateTime?
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("receipts")
}

model Cottages {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  createdAt   DateTime @default(now())
  booking     Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId   Int?

  @@map("cottages")
}

model DefaultChatNodes {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  createdAt DateTime @default(now())

  @@map("default_chat_nodes")
}
